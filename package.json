    "@typescript-eslint/parser": "^8.32.0",
    "@zaiusinc/eslint-config-presets": "3.1.3-dev.1",
    "copyfiles": "^2.4.1",
    "eslint": "^9.25.1",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.2",
    "vite": "^5.4.19"
